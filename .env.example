# Copy to .env.local for local development. Set these in Vercel Project → Settings → Environment Variables.

# --- Database (required for sign-up & listings). Use ONE of these: ---
MONGODB_URI=

# Alternate names supported by Listfy (Atlas / some hosts use these):
# MONGO_URL=

# DATABASE_URL only if your string starts with mongodb:// or mongodb+srv://
# DATABASE_URL=

MONGODB_DB=listfy

# Optional: comma-separated DNS resolvers if mongodb+srv SRV lookups fail locally
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# --- Auth (required in production). Generate NEXTAUTH_SECRET with: openssl rand -base64 32 ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Production: set NEXTAUTH_URL to https://your-production-domain.com on Vercel.
# trustHost is enabled when VERCEL=1. Self‑hosted production (no Vercel): if cookies/redirects fail, set:
# AUTH_TRUST_HOST=true

# Admin users (comma-separated). In production there are NO built-in demo admins — configure this explicitly.
ADMIN_EMAIL=

# OAuth (optional; enable whichever you need)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Optional: AI listing copy ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Optional: full /api/health diagnostics in production ---
# Without this secret, production health returns only { ok, mongo }. With it, pass ?secret=... or header x-health-secret.
# HEALTH_CHECK_SECRET=

# --- Optional: local JSON listing fallback directory (defaults: ./.data locally, /tmp/listfy-data on Vercel) ---
# LISTFY_DATA_DIR=
